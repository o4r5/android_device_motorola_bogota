/system         erofs   /dev/block/mapper/system            flags=display="System";slotselect
/vendor         erofs   /dev/block/mapper/vendor            flags=display="Vendor";slotselect
/data           f2fs    /dev/block/by-name/userdata         flags=display="Data";fileencryption=aes-256-xts:aes-256-cts:v2+inlinecrypt_optimized+wrappedkey_v0
/metadata       f2fs    /dev/block/by-name/metadata         flags=display="Metadata"
/persist        ext4    /dev/block/by-name/persist          flags=display="Persist"
/sdcard1        auto    /dev/block/mmcblk1p1                flags=display="MicroSD";storage;wipeingui;removable
